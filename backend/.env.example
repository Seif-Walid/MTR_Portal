# Copy to .env and adjust.

# PostgreSQL (default; matches docker-compose.yml at the repo root)
DATABASE_URL=postgresql+psycopg://portal:portal@localhost:5432/portal

# Quick local run without Postgres (dev only):
# DATABASE_URL=sqlite:///./portal_dev.db

SESSION_TTL_HOURS=168
COOKIE_SECURE=false
MAX_UPLOAD_MB=25

# Where to send users back to after Google sign-in
FRONTEND_URL=http://localhost:5173

# Google SSO (optional). Create an OAuth 2.0 Client ID (type: Web application)
# in Google Cloud Console and add GOOGLE_REDIRECT_URI to its authorized
# redirect URIs. Only emails that already exist as portal users can sign in —
# Google sign-in never creates an account. A password account's first Google
# sign-in requires linking explicitly (sign in with the password once, then
# "Link Google account" from the account menu) rather than being matched by
# email alone.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# Comma-separated domain allowlist for Google sign-in, checked against the
# Workspace `hd` claim (or the email's own domain for personal accounts, since
# Gmail has no `hd`). Leave blank for no restriction. Set to your org's
# Workspace domain to lock it down, and add e.g. gmail.com to deliberately
# permit personal accounts rather than by accident.
# GOOGLE_ALLOWED_DOMAINS=mindtechrobotics.org,gmail.com
GOOGLE_ALLOWED_DOMAINS=

# Google Sheets inventory mirror (optional). The portal stays the source of
# truth; "Sync to Sheets" pushes a read-only snapshot. Create a service account
# in Google Cloud Console, enable the Google Sheets API, download its JSON key,
# and SHARE the target spreadsheet with the service account's email. Leave blank
# to disable (the Sync button stays disabled).
GOOGLE_SHEETS_CREDENTIALS_FILE=
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_WORKSHEET=Inventory

# Your org's name — shown across the UI and also the exact phrase an admin
# must type to confirm the destructive "Rebuild from Sheets" action. The
# frontend reads this from GET /api/sync/status, so changing it here is
# enough; nothing needs editing in the frontend code.
ORG_NAME=Mind-Tech Robotics
