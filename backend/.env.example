# Copy to .env and adjust.

# PostgreSQL (default; matches docker-compose.yml at the repo root)
DATABASE_URL=postgresql+psycopg://portal:portal@localhost:5432/portal

# Quick local run without Postgres (dev only):
# DATABASE_URL=sqlite:///./portal_dev.db

SESSION_TTL_HOURS=168
COOKIE_SECURE=false
MAX_UPLOAD_MB=25

# Where to send users back to after Google sign-in
FRONTEND_URL=http://localhost:5173

# Google SSO (optional). Create an OAuth 2.0 Client ID (type: Web application)
# in Google Cloud Console and add GOOGLE_REDIRECT_URI to its authorized
# redirect URIs. Only emails that already exist as portal users can sign in.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
